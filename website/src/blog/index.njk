---
layout: base.njk
title: Blog
---

<section class="section-blog section-dark">
  <div class="blog-inner">
    <div class="hook-label">Build Diary</div>
    <h1 class="blog-headline"><span class="grad1">synlynk</span> Blog</h1>
    <p class="blog-sub">Documenting the design choices, pivots, and architectural details of the OS for multi-agent development.</p>

    <div class="blog-grid">
      {% for post in collections.posts %}
        {% set heroImage = blogHeroes[post.fileSlug] %}
        <article class="blog-card">
          <a href="{{ post.url }}" class="blog-card-img-link">
            {% if heroImage %}
              <div class="blog-card-hero-wrap">
                <img src="/{{ heroImage }}" alt="{{ post.data.title }}" class="blog-card-hero">
              </div>
            {% else %}
              <div class="blog-card-hero-fallback fallback-grad-{{ (post.data.post or 0) % 4 }}">
                <span class="fallback-post-num">#{{ post.data.post or '00' }}</span>
              </div>
            {% endif %}
          </a>
          <div class="blog-card-content">
            <div class="blog-card-meta">
              <span class="blog-card-date">{{ post.date | dateFilter }}</span>
              {% if post.data.pr %}
                <span class="blog-card-pr">{{ post.data.pr }}</span>
              {% endif %}
            </div>
            <h2 class="blog-card-title">
              <a href="{{ post.url }}">{{ post.data.title }}</a>
            </h2>
            <p class="blog-card-excerpt">
              {{ post.templateContent | striptags | truncate(140) }}
            </p>
            <a href="{{ post.url }}" class="blog-card-link">Read Post →</a>
          </div>
        </article>
      {% else %}
        <p class="no-posts">No blog posts found.</p>
      {% endfor %}
    </div>
  </div>
</section>
