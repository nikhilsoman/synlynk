<!-- Section 1: Tagline Hero (dark, 100vh) -->
<section id="top" class="section-tagline section-dark">
  <div class="hook-label">Multi-agent coordination</div>

  <p class="hero-byline">Most developers use one agent at a time.</p>

  <h1 class="hero-headline">
    <span class="grad1">synlynk</span> lets you run<br>a workgroup.
  </h1>

  <p class="hero-sub">
    Spread the work, spread the cost.
    Different models, different strengths,
    <strong>one shared project state</strong>.
  </p>

  <div class="hero-cta-row">
    <a href="/#waitlist" class="btn-primary">
